apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: sriov
  namespace: argocd
  finalizers:
  - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    chart: sriov
    repoURL: https://amrbaraka.github.io/helm-charts/
    targetRevision: 0.1.1
  destination:
    server: https://kubernetes.default.svc
    namespace: default
  syncPolicy:    
    automated:
      prune: true
      selfHeal: true
