apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: ueransim
  namespace: argocd
  finalizers:
  - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: https://github.com/5g-cloud-labs/new-test.git
    targetRevision: main
    path: 4-UERANSIM/ueransim-chart
    helm:
      values: |
          gnb:
            name: gnb
            configuration1: |-
              mcc: $mcc
              mnc: $mnc
          ue:
            name: ue
            command: "./nr-ue -c ../config/ue-config.yaml -n ${count}"
            configuration1: |-
              mcc: $mcc 
              mnc: $mnc 
              supi: "imsi-${mcc}${mnc}${start_msin}"
       
  destination:
    server: https://kubernetes.default.svc
    namespace: ueransim
  syncPolicy:    
    automated:
      prune: true
      selfHeal: true
