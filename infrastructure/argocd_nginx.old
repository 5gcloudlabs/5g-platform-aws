resource "argocd_application" "nginx_app" {
#  depends_on = [helm_release.argocd, time_sleep.wait_post_ingress]

  metadata {
    name      = "nginx-app"
    namespace = "argocd"
  }

  spec {
    project = "default"

    source {
      repo_url        = "https://github.com/5g-cloud-labs/new-test-2.git"
      target_revision = "trims"
      path            = "argocd-apps/nginx-app"


     plugin {

        name = "envsubst"

        env {
          name  = "DOMAIN_NAME"
          value = var.domain_name
        }

        env {
          name  = "EFS_ID"
          value = module.efs.id
        }

        env {
          name  = "CF_API_TOKEN"
          value = var.cloudflare_api_token
        }

        env {
          name  = "EFS_ARN"
          value = aws_iam_role.aws_efs_csi_driver_role.arn
        }


        env {
          name  = "EKS_CLUSTER_NAME"
          value = module.eks.cluster_name
        }

        env {
          name  = "LBC_IAM_ROLE_ARN"
          value = aws_iam_role.aws_load_balancer_controller_role.arn
        }






      }


    }


    destination {
      server    = "https://kubernetes.default.svc"
      namespace = "argocd"
    }

    sync_policy {
      automated {
        prune      = true
        self_heal  = true
      }
    }
  }
}
